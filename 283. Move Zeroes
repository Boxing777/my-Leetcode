class Solution {
public:
    void moveZeroes(vector<int>& nums) {
        int fastIndex=0,slowIndex=0;

        for(fastIndex; fastIndex<nums.size(); fastIndex++){
            if(nums[fastIndex]!=0){
                int temp=nums[slowIndex];
                nums[slowIndex]=nums[fastIndex];
                nums[fastIndex]=temp; 
                slowIndex++;
            }
        }

        return;   
    }
};
