class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int cand=0, count=0;
        for(int i=0; i<nums.size(); i++){
            if(count==0){
                cand=nums[i];
            }
            
            if(nums[i]!=cand){
                count--;
            }else{
                count++;
            }
        }
        return cand;
    }
};

5.
class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int ans=0;

        for(int i=0; i<32; i++){
            int count=0;
            for(int num:nums){
                if((num>>i) & 1) count++;
            }

            if(count > nums.size()/2){
                ans |= 1<<i;
            }
        }
        return ans;
    }
};
