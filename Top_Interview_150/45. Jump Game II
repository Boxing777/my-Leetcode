class Solution {
public:
    int jump(vector<int>& nums) {
        int n=nums.size();
        if(n==1) return 0;

        int jump=0, currentEnd=0, farthest=0;
        for(int i=0; i<n-1; i++){
            farthest=max(farthest, i+nums[i]);

            if(i==currentEnd){
                jump++;
                currentEnd=farthest;

                if(currentEnd>=n-1) break;
            }
        }

        return jump;
    }
};
