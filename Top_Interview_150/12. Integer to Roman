
class Solution { // good
public:
    string intToRoman(int num) {
        string ans="";

        string ths[]={"", "M", "MM", "MMM"};
        string hrds[]={"", "C", "CC", "CCC", "CD", "D", "DC", "DCC", "DCCC", "CM"};
        string tens[]={"", "X", "XX", "XXX", "XL", "L", "LX", "LXX", "LXXX", "XC"};
        string ones[]={"", "I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX"};

        ans=ths[num/1000]+hrds[(num%1000)/100]+tens[(num%100)/10]+ones[(num%10)];

        return ans;
    }
};

class Solution {
public:
    string intToRoman(int num) {
        string ans="";

        vector<int> val={
            1000, 900, 500, 400, 100,
            90, 50, 40, 10, 9, 5, 4, 1
        };

        vector<string> symbols={
            "M", "CM", "D", "CD", "C", "XC",
            "L", "XL", "X", "IX", "V", "IV", "I"
        };

        for(int i=0; i<val.size(); i++){
            while(num>=val[i]){
                num-=val[i];
                ans+=symbols[i];
            }   
        }

        return ans;
    }
};
