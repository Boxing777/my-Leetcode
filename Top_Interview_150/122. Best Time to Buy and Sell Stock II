class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int ans=0;

        for(int i=0; i<prices.size()-1; i++){
            int profit=0;
            profit = (-prices[i]+prices[i+1])>0 ? -prices[i]+prices[i+1] : 0;
            ans+=profit;
        }

        return ans;
    }
};
