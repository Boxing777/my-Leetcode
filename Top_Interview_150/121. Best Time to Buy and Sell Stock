class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int min=INT_MAX, max=INT_MIN;
        int indexMin=0, indexMax=0,ans=0;
        for(int i=0; i<prices.size(); i++){
            if(prices[i]<min){
                min=prices[i];
                max=INT_MIN;
            }
            if(prices[i]>max){
                max=prices[i];
                ans = (max-min)>ans ? max-min: ans; 
            }
        }

        return ans;
    }
};
